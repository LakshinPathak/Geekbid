# ─────────────────────────────────────────────────
# GeekBid Mobile — Frontend (Expo) Environment
# Copy to .env.development / .env.production / .env.staging
# ─────────────────────────────────────────────────

# Toggle mock data (set to false for real API)
EXPO_PUBLIC_USE_MOCK=true

# API Gateway URL
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000/v1

# Bidding WebSocket URL
EXPO_PUBLIC_SOCKET_URL=http://localhost:3004

# Auth token (populated at runtime after login)
EXPO_PUBLIC_AUTH_TOKEN=
