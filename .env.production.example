# ─────────────────────────────────────────────────
# GeekBid — Production Environment Template
# Copy to .env.production and fill in real values
# ─────────────────────────────────────────────────

# ── Shared ────────────────────────────────────────
NODE_ENV=production

# ── MongoDB Atlas (Production M10+ cluster) ──────
# Use a dedicated production cluster with:
#   - M10+ tier (or higher for scale)
#   - Auto-backup enabled
#   - IP Access List configured
#   - Read/Write user credentials (not atlas admin)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/geekbid?retryWrites=true&w=majority

# ── JWT Secrets ──────────────────────────────────
# Generate with: openssl rand -base64 64
# MUST be different from development secrets
JWT_SECRET=
NEXTAUTH_SECRET=

# ── App URLs ─────────────────────────────────────
NEXTAUTH_URL=https://geekbid.io

# ── Google OAuth ─────────────────────────────────
# Production OAuth credentials from Google Cloud Console
# Redirect URI must be: https://geekbid.io/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Razorpay (LIVE keys) ────────────────────────
# Switch from rzp_test_ to rzp_live_ for production
RAZORPAY_KEY_ID=rzp_live_YOUR_KEY_ID
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ── Error Monitoring ────────────────────────────
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# ── Analytics ────────────────────────────────────
POSTHOG_API_KEY=
NEXT_PUBLIC_POSTHOG_KEY=

# ── Email (Transactional) ───────────────────────
RESEND_API_KEY=
EMAIL_FROM=noreply@geekbid.io

# ── Seed Endpoint ───────────────────────────────
# Keep this false (or omit) in production!
ALLOW_SEED=false

# ── Service Ports (backend microservices) ────────
GATEWAY_PORT=3000
AUTH_PORT=3001
JOB_PORT=3003
BIDDING_PORT=3004
PAYMENT_PORT=3005
NOTIFICATION_PORT=3006
CHAT_PORT=3007
