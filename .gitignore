# ─────────────────────────────────────────────────
# GeekBid Mobile — .gitignore
# Covers: Expo/React-Native, Next.js (web), Node.js (backend)
# ─────────────────────────────────────────────────

# ──── Dependencies ────
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ──── Environment Files (NEVER commit secrets) ────
# Root-level
.env
.env.local
.env.development
.env.staging
.env.production
.env*.local

# All nested .env files (backend/, web/, etc.)
**/.env
**/.env.local
**/.env*.local

# ✅ EXCEPTION: .env.example templates ARE committed
!.env.example
!**/.env.example

# ──── Expo / React-Native ────
.expo/
dist/
web-build/
expo-env.d.ts
.metro-health-check*

# Native build outputs
/ios/
/android/
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# ──── Next.js (web/) ────
.next/
out/
build/
.vercel

# ──── Testing / Coverage ────
coverage/
__snapshots__/

# ──── TypeScript ────
*.tsbuildinfo
next-env.d.ts

# ──── OS Files ────
.DS_Store
Thumbs.db
*.pem

# ──── Debug Logs ────
npm-debug.*
yarn-debug.*
yarn-error.*
.pnpm-debug.log*
*.log

# ──── IDE / Editor ────
.vscode/
.idea/
*.swp
*.swo
*~
