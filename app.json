{
  "expo": {
    "name": "GeekBid",
    "slug": "geekbid-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "geekbid",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B1020"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "io.geekbid.mobile",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "GeekBid uses the camera for profile and project uploads.",
        "NSPhotoLibraryUsageDescription": "GeekBid uses your photos for profile and portfolio media.",
        "NSMicrophoneUsageDescription": "GeekBid uses the microphone for optional voice features."
      }
    },
    "android": {
      "package": "io.geekbid.mobile",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0B1020"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "INTERNET",
        "POST_NOTIFICATIONS",
        "CAMERA",
        "READ_MEDIA_IMAGES"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "00000000-0000-0000-0000-000000000000"
      }
    }
  }
}
