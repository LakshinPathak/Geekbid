# ─────────────────────────────────────────────────
# GeekBid Backend — Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────

# MongoDB Atlas Connection (required)
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/geekbid?retryWrites=true&w=majority
MONGODB_URI=

# JWT Secret — generate with: openssl rand -base64 32
JWT_SECRET=

# Razorpay Test Mode Keys
# Get your test keys from https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_YOUR_KEY_ID
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Service Ports (defaults shown — override if needed)
GATEWAY_PORT=3000
AUTH_PORT=3001
JOB_PORT=3003
BIDDING_PORT=3004
PAYMENT_PORT=3005
NOTIFICATION_PORT=3006
CHAT_PORT=3007
